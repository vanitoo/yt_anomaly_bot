# --- Telegram ---
TELEGRAM_BOT_TOKEN=8505340627:AAEIgFjFwwptk1fS8fjwXNZzyc3bRbPeal8
TELEGRAM_CHAT_ID=your_chat_id_here
ADMIN_USER_IDS=319415227

# --- YouTube ---
YOUTUBE_API_KEY=your_youtube_api_key_here

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db
##DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/yt_anomaly_bot

# --- Analysis Defaults ---
DEFAULT_THRESHOLD=1.8
DEFAULT_MIN_VIEWS=5000
DEFAULT_MIN_AGE_DAYS=7
DEFAULT_PERIOD_DAYS=90
DEFAULT_BASELINE_METHOD=median
DEFAULT_INCLUDE_SHORTS=false
DEFAULT_INCLUDE_FRESH_IN_BASELINE=false

# --- Scheduler ---
# weekly | daily | hourly
SCHEDULE_INTERVAL=weekly

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
