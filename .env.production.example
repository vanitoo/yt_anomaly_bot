# ============================================================
# Docker Production Environment
# Copy this file to .env and configure for your setup
# ============================================================

# --- Telegram (required) ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
ADMIN_USER_IDS=123456789

# --- YouTube (required) ---
YOUTUBE_API_KEY=your_youtube_api_key_here

# --- Database (PostgreSQL via Docker) ---
DATABASE_URL=postgresql+asyncpg://ytbot:changeme@postgres:5432/yt_anomaly_bot

# --- PostgreSQL (for docker-compose) ---
POSTGRES_USER=ytbot
POSTGRES_PASSWORD=changeme
POSTGRES_DB=yt_anomaly_bot

# --- Analysis Defaults ---
DEFAULT_THRESHOLD=1.8
DEFAULT_MIN_VIEWS=5000
DEFAULT_MIN_AGE_DAYS=7
DEFAULT_PERIOD_DAYS=90
DEFAULT_BASELINE_METHOD=median

# --- Scheduler ---
SCHEDULE_INTERVAL=weekly

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
